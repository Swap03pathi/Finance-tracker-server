# Server env (doc 07 §12 / doc 10 §0). Copy to .env on the EC2 box — NEVER commit real values.
# All secrets are server-side only; the app/device never sees them.

# RDS PostgreSQL connection (use the RDS endpoint; sslmode=require for RDS)
DATABASE_URL="postgresql://finman:CHANGE_ME@<rds-endpoint>:5432/finman?schema=public&sslmode=require"

# OpenAI — template induction only (rare; behind the provider abstraction)
OPENAI_API_KEY=""
LLM_PROVIDER="openai"

# Google Sign-In — server verifies the ID token against Google certs
GOOGLE_CLIENT_ID=""

PORT="3000"
NODE_ENV="production"
