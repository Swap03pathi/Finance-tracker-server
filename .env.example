# Copy to .env and fill in. NEVER commit .env.
# Postgres (matches docker-compose.yml)
DATABASE_URL="postgresql://finman:finman@localhost:5432/finman?schema=public"

# OpenAI (template induction only — rare, behind a swappable provider interface)
OPENAI_API_KEY=""
LLM_PROVIDER="openai"

# Google Sign-In (server-side ID token verification)
GOOGLE_CLIENT_ID=""

# App
PORT="3000"
NODE_ENV="development"
